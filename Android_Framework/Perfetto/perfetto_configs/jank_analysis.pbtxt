# 文件路径:Android_Framework_Layer/Perfetto/perfetto_configs/jank_analysis.pbtxt
# 场景:卡顿分析专项
# 适用:UI 卡顿、滑动掉帧、动画卡顿
# 抓取时长:30s(短时深度调查)

duration_ms: 30000

buffers {
  size_kb: 4096
  fill_policy: RING_BUFFER
}

# ===== 渲染事件(重点) =====
data_sources {
  config {
    name: "android.atrace"
    atrace_config {
      atrace_categories: "gfx"          # 图形
      atrace_categories: "view"          # View 树
      atrace_categories: "input"         # 输入事件
      atrace_categories: "wm"            # WindowManager
      atrace_categories: "am"            # AMS(看 Activity 切换)
    }
  }
}

# ===== 调度事件(找主线程切换) =====
data_sources {
  config {
    name: "linux.ftrace"
    ftrace_config {
      ftrace_events: "sched/sched_switch"
      ftrace_events: "sched/sched_wakeup"
      ftrace_events: "sched/sched_blocked_reason"
      ftrace_events: "sched/sched_cpu_hotplug"
    }
  }
}

# ===== CPU 频率(看降频) =====
data_sources {
  config {
    name: "android.atrace"
    atrace_config {
      atrace_categories: "freq"
      atrace_categories: "idle"
    }
  }
}

# ===== Binder(看是否有跨进程阻塞) =====
data_sources {
  config {
    name: "android.atrace"
    atrace_config {
      atrace_categories: "binder"
    }
  }
}

unique_session_name: "jank_analysis_v1"
session_initiator: INTERNAL_INCIATED
