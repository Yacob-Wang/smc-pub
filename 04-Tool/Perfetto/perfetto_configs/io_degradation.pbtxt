# 文件路径:Android_Framework_Layer/Perfetto/perfetto_configs/io_degradation.pbtxt
# 场景:IO 性能劣化专项追踪
# 适用:冷启动退化、磁盘慢、文件读慢问题
# 抓取时长:60s,触发方式:statsd IO 阈值告警

duration_ms: 60000

buffers {
  size_kb: 8192
  fill_policy: RING_BUFFER
}

trigger_config {
  trigger_mode: STOP_TRACING
  trigger_name: "io_degradation_observer"
  stop_ms: 30000
}

# ===== 块 IO 事件(重点) =====
data_sources {
  config {
    name: "linux.ftrace"
    ftrace_config {
      ftrace_events: "block/block_rq_complete"
      ftrace_events: "block/block_rq_issue"
      ftrace_events: "block/block_bio_complete"
      ftrace_events: "block/block_bio_backmerge"
      ftrace_events: "block/block_plug"
      ftrace_events: "block/block_unplug"
    }
  }
}

# ===== 文件系统事件 =====
data_sources {
  config {
    name: "linux.ftrace"
    ftrace_config {
      ftrace_events: "ext4/ext4_da_write_begin"
      ftrace_events: "ext4/ext4_da_write_end"
      ftrace_events: "ext4/ext4_sync_file"
      ftrace_events: "f2fs/f2fs_write_begin"
      ftrace_events: "f2fs/f2fs_write_end"
      ftrace_events: "f2fs/f2fs_sync_file"
    }
  }
}

# ===== 写回事件 =====
data_sources {
  config {
    name: "linux.ftrace"
    ftrace_config {
      ftrace_events: "writeback/writeback_start"
      ftrace_events: "writeback/writeback_end"
      ftrace_events: "writeback/writeback_pages_written"
    }
  }
}

# ===== 调度事件(找 D 状态) =====
data_sources {
  config {
    name: "linux.ftrace"
    ftrace_config {
      ftrace_events: "sched/sched_switch"
      ftrace_events: "sched/sched_wakeup"
      ftrace_events: "sched/sched_blocked_reason"
    }
  }
}

# ===== atrace:disk 类目 =====
data_sources {
  config {
    name: "android.atrace"
    atrace_config {
      atrace_categories: "disk"
      atrace_categories: "freq"
      atrace_categories: "idle"
    }
  }
}

# ===== 进程统计 =====
data_sources {
  config {
    name: "linux.process_stats"
    process_stats_config {
      proc_stats_poll_interval_ms: 500
    }
  }
}

# ===== 系统统计 =====
data_sources {
  config {
    name: "linux.sys_stats"
    sys_stats_config {
      sys_stats_poll_interval_ms: 500
    }
  }
}

unique_session_name: "io_degradation_v1"
session_initiator: INTERNAL_INCIATED
